#include <stdio.h>
#include <string.h>

int countPairs(char arr[][100], int n) {
    int count = 0;
    int len = strlen(arr[0]);

    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {

            int diff = 0;

            for (int k = 0; k < len; k++) {
                if (arr[i][k] != arr[j][k]) {
                    diff++;
                    if (diff > 1) break; // early stop
                }
            }

            if (diff == 1)
                count++;
        }
    }

    return count;
}

int main() {
    char arr[][100] = {"abc", "abd", "bbd"};
    int n = 3;

    printf("%d\n", countPairs(arr, n)); // Output: 2

    return 0;
}
