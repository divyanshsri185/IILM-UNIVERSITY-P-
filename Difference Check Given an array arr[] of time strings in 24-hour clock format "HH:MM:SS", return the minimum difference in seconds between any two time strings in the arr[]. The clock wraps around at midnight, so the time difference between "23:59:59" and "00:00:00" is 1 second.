#include <stdio.h>
#include <stdlib.h>

// Convert "HH:MM:SS" → seconds
int toSeconds(char *t) {
    int h, m, s;
    sscanf(t, "%d:%d:%d", &h, &m, &s);
    return h * 3600 + m * 60 + s;
}

// Compare function for sorting
int cmp(const void *a, const void *b) {
    return (*(int *)a - *(int *)b);
}

int minTimeDiff(char *arr[], int n) {
    int sec[1000];

    // Step 1: Convert
    for (int i = 0; i < n; i++) {
        sec[i] = toSeconds(arr[i]);
    }

    // Step 2: Sort
    qsort(sec, n, sizeof(int), cmp);

    // Step 3: Adjacent difference
    int minDiff = 86400;

    for (int i = 1; i < n; i++) {
        int diff = sec[i] - sec[i - 1];
        if (diff < minDiff)
            minDiff = diff;
    }

    // Step 4: Circular difference
    int wrap = 86400 - (sec[n - 1] - sec[0]);
    if (wrap < minDiff)
        minDiff = wrap;

    return minDiff;
}

int main() {
    char *arr[] = {"00:00:01", "23:59:59", "00:00:05"};
    int n = 3;

    printf("%d\n", minTimeDiff(arr, n)); // Output: 2

    return 0;
}
