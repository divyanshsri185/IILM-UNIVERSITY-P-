#include <stdio.h>

// Find pivot (index of smallest element)
int findPivot(int arr[], int n) {
    int low = 0, high = n - 1;

    while (low < high) {
        int mid = (low + high) / 2;

        if (arr[mid] > arr[high])
            low = mid + 1;
        else
            high = mid;
    }
    return low;
}

// Count elements <= x using binary search
int countLE(int arr[], int low, int high, int x) {
    int ans = -1;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (arr[mid] <= x) {
            ans = mid;
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }

    if (ans == -1) return 0;
    return ans - low + (high - ans + 1); // simplified below
}
