#include <stdio.h>
#include <limits.h>

int findMin(int a[100][100], int r1, int c1, int r2, int c2) {
    int min = INT_MAX;
    for (int i = r1; i <= r2; i++) {
        for (int j = c1; j <= c2; j++) {
            if (a[i][j] < min)
                min = a[i][j];
        }
    }
    return min;
}

int main() {
    int n = 3, m = 3;
    int a[100][100] = {
        {1,2,3},
        {4,5,6},
        {7,8,9}
    };

    int q = 1;
    int queries[1][2] = {{2,2}};

    for (int k = 0; k < q; k++) {
        int R = queries[k][0] - 1; // convert to 0-based
        int C = queries[k][1] - 1;

        int sum = 0;

        // Top-left
        if (R-1 >= 0 && C-1 >= 0)
            sum += findMin(a, 0, 0, R-1, C-1);

        // Top-right
        if (R-1 >= 0 && C+1 <= m-1)
            sum += findMin(a, 0, C+1, R-1, m-1);

        // Bottom-left
        if (R+1 <= n-1 && C-1 >= 0)
            sum += findMin(a, R+1, 0, n-1, C-1);

        // Bottom-right
        if (R+1 <= n-1 && C+1 <= m-1)
            sum += findMin(a, R+1, C+1, n-1, m-1);

        printf("%d\n", sum);
    }

    return 0;
}
