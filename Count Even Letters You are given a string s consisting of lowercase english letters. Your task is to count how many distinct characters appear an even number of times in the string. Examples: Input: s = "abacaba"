#include <stdio.h>
#include <string.h>

int countEvenLetters(char s[]) {
    int freq[26] = {0};

    // Count frequency
    for (int i = 0; i < strlen(s); i++) {
        freq[s[i] - 'a']++;
    }

    int count = 0;

    // Count even frequencies
    for (int i = 0; i < 26; i++) {
        if (freq[i] > 0 && freq[i] % 2 == 0) {
            count++;
        }
    }

    return count;
}

int main() {
    char s[] = "abacaba";

    printf("%d\n", countEvenLetters(s)); // Output: 2

    return 0;
}
