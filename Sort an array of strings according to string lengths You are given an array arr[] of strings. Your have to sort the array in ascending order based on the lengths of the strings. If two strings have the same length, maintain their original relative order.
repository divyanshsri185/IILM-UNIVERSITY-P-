#include <stdio.h>
#include <string.h>

void sortByLength(char arr[][100], int n) {
    char temp[100];

    // Bubble Sort (stable)
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {

            if (strlen(arr[j]) > strlen(arr[j + 1])) {
                // swap
                strcpy(temp, arr[j]);
                strcpy(arr[j], arr[j + 1]);
                strcpy(arr[j + 1], temp);
            }
        }
    }
}

int main() {
    char arr[][100] = {"GeeksforGeeks", "I", "from", "am"};
    int n = 4;

    sortByLength(arr, n);

    for (int i = 0; i < n; i++) {
        printf("%s ", arr[i]);
    }

    return 0;
}
