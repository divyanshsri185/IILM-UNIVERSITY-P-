#include <stdio.h>
#include <string.h>

int minSwaps(char s1[], char s2[]) {
    int count01 = 0, count10 = 0;
    int n = strlen(s1);

    for (int i = 0; i < n; i++) {
        if (s1[i] == '0' && s2[i] == '1')
            count01++;
        else if (s1[i] == '1' && s2[i] == '0')
            count10++;
    }

    int total = count01 + count10;

    if (total % 2 != 0)
        return -1;

    return total / 2;
}

int main() {
    char s1[] = "1100";
    char s2[] = "1111";

    printf("%d\n", minSwaps(s1, s2)); // Output: 1

    return 0;
}
