#include <stdio.h>
#include <string.h>
#include <stdlib.h>

typedef struct {
    char ch;
    int freq;
} Node;

// Comparator
int cmp(const void *a, const void *b) {
    Node *x = (Node *)a;
    Node *y = (Node *)b;

    if (x->freq != y->freq)
        return x->freq - y->freq; // ascending freq
    return x->ch - y->ch;         // lexicographical
}

int main() {
    char s[] = "geeksforgeeks";
    int n = strlen(s);

    int freq[256] = {0};

    // Step 1: Count frequency
    for (int i = 0; i < n; i++) {
        freq[s[i]]++;
    }

    // Step 2: Store unique characters
    Node arr[256];
    int k = 0;

    for (int i = 0; i < 256; i++) {
        if (freq[i] > 0) {
            arr[k].ch = (char)i;
            arr[k].freq = freq[i];
            k++;
        }
    }

    // Step 3: Sort
    qsort(arr, k, sizeof(Node), cmp);

    // Step 4: Build result
    for (int i = 0; i < k; i++) {
        for (int j = 0; j < arr[i].freq; j++) {
            printf("%c", arr[i].ch);
        }
    }

    return 0;
}
