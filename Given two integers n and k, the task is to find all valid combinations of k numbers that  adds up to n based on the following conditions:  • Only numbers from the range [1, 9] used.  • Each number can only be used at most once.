#include <stdio.h>

int result[100][10];
int resultSize = 0;

void backtrack(int start, int k, int sum, int temp[], int tempSize) {
    
    // Valid combination
    if (k == 0 && sum == 0) {
        for (int i = 0; i < tempSize; i++) {
            result[resultSize][i] = temp[i];
        }
        resultSize++;
        return;
    }

    // Stop condition
    if (k == 0 || sum < 0) return;

    for (int i = start; i <= 9; i++) {
        temp[tempSize] = i;

        backtrack(i + 1, k - 1, sum - i, temp, tempSize + 1);
    }
}

int main() {
    int n = 9, k = 3;

    int temp[10];

    backtrack(1, k, n, temp, 0);

    // Print result
    for (int i = 0; i < resultSize; i++) {
        printf("[ ");
        for (int j = 0; j < k; j++) {
            printf("%d ", result[i][j]);
        }
        printf("]\n");
    }

    return 0;
}
