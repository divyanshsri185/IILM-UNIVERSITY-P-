#include <stdio.h>
#include <string.h>

int minAddToMakeValid(char s[]) {
    int open = 0; // unmatched '('
    int add = 0;  // insertions needed

    for (int i = 0; i < strlen(s); i++) {
        if (s[i] == '(') {
            open++;
        } else { // ')'
            if (open > 0) {
                open--; // match
            } else {
                add++; // need '('
            }
        }
    }

    return add + open;
}

int main() {
    char s[] = "(()(";

    printf("%d\n", minAddToMakeValid(s)); // Output: 2

    return 0;
}
