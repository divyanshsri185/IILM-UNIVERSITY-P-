


#include <stdio.h>

int countSubarrays(int arr[], int n) {
    int stack[1000];
    int top = -1;
    int nextSmaller[1000];

    // Step 1: Find Next Smaller Element index
    for (int i = n - 1; i >= 0; i--) {

        while (top >= 0 && arr[stack[top]] >= arr[i]) {
            top--;
        }

        if (top == -1)
            nextSmaller[i] = n;
        else
            nextSmaller[i] = stack[top];

        stack[++top] = i;
    }

    // Step 2: Count contributions
    int total = 0;
    for (int i = 0; i < n; i++) {
        total += (nextSmaller[i] - i);
    }

    return total;
}

int main() {
    int arr[] = {1, 2, 1};
    int n = 3;

    printf("%d\n", countSubarrays(arr, n)); // Output: 5

    return 0;
}
