#include <stdio.h>

long long arraySum(int arr[], int n) {
    long long sum = 0;

    for (int i = 0; i < n; i++) {
        sum += arr[i];
    }

    return sum;
}

int main() {
    int arr[] = {6, 2, 5, 4, 5, 1, 6};
    int n = 7;

    printf("%lld\n", arraySum(arr, n)); // Output: 29

    return 0;
}
