#include <stdio.h>
#include <string.h>
#include <stdbool.h>

bool checkPermutationSubstring(char txt[], char pat[]) {
    int n = strlen(txt);
    int m = strlen(pat);

    if (m > n) return false;

    int freqPat[26] = {0};
    int freqWin[26] = {0};

    // Step 1: Count pattern frequency
    for (int i = 0; i < m; i++) {
        freqPat[pat[i] - 'a']++;
        freqWin[txt[i] - 'a']++;
    }

    // Step 2: Sliding window
    for (int i = m; i <= n; i++) {

        // Compare arrays
        int match = 1;
        for (int j = 0; j < 26; j++) {
            if (freqPat[j] != freqWin[j]) {
                match = 0;
                break;
            }
        }

        if (match) return true;

        // Slide window
        if (i < n) {
            freqWin[txt[i] - 'a']++;         // add new
            freqWin[txt[i - m] - 'a']--;     // remove old
        }
    }

    return false;
}

int main() {
    char txt[] = "geeks";
    char pat[] = "eke";

    if (checkPermutationSubstring(txt, pat))
        printf("true\n");
    else
        printf("false\n");

    return 0;
}
