#include <stdio.h>

int maxVisible(int arr[], int n) {
    int left[1000] = {0};
    int right[1000] = {0};

    int stack[1000], top;

    // LEFT VISIBILITY
    top = -1;
    for (int i = 0; i < n; i++) {
        int count = 0;

        while (top >= 0 && stack[top] < arr[i]) {
            count++;
            top--;
        }

        if (top >= 0) count++; // can see blocker also

        left[i] = count;
        stack[++top] = arr[i];
    }

    // RIGHT VISIBILITY
    top = -1;
    for (int i = n - 1; i >= 0; i--) {
        int count = 0;

        while (top >= 0 && stack[top] < arr[i]) {
            count++;
            top--;
        }

        if (top >= 0) count++;

        right[i] = count;
        stack[++top] = arr[i];
    }

    // Find maximum
    int max = 0;
    for (int i = 0; i < n; i++) {
        int total = left[i] + right[i] + 1;
        if (total > max)
            max = total;
    }

    return max;
}

int main() {
    int arr[] = {6, 2, 5, 4, 5, 1, 6};
    int n = 7;

    printf("%d\n", maxVisible(arr, n)); // Output: 6

    return 0;
}
